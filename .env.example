# Credenciales FTP
# IMPORTANTE: nunca commites este archivo con valores reales al repositorio.
# Copia este archivo como .env y rellena los valores.

FTP_HOST=tu_dominio.com
FTP_USER=tu_usuario_ftp
FTP_PASS=tu_contraseña_ftp
FTP_PUBLIC_HTML=public_html

# Seguridad (Requerido)
SECRET_KEY=generate_a_secure_random_key_here

# Nivel de logs: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Radio máximo en km para asignar municipio más cercano (geocodificación)
GEO_PROXIMITY_KM=50
